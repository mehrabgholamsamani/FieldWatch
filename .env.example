# FieldWatch — Environment Variables
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://fieldwatch:fieldwatch@db:5432/fieldwatch

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=fieldwatch-uploads
AWS_REGION=eu-north-1

# ── Geocoding ─────────────────────────────────────────────────────────────────
# Must be a descriptive string per Nominatim policy (e.g. "myapp/1.0 contact@myapp.com")
NOMINATIM_USER_AGENT=fieldwatch-dev

# ── Push Notifications ────────────────────────────────────────────────────────
# JSON string of Firebase service account credentials.
# Leave as {} to disable push notifications (graceful degradation).
FIREBASE_CREDENTIALS_JSON={}

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (pydantic parses JSON arrays from env)
# Example for production: '["https://app.fieldwatch.io"]'
CORS_ORIGINS=["http://localhost:8081","http://localhost:19006"]
